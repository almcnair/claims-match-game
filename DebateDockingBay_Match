<script>
// ── Card data ──
const CARDS = [
  { id: 'c1', term: 'claim',   tag: 'Definition', text: 'This is your main point or the "headline" of your argument. It is a simple statement of what you want or what you believe is true.' },
  { id: 'c2', term: 'claim',   tag: 'Example',    text: '"I want a 10:00 PM bedtime."' },
  { id: 'w1', term: 'warrant', tag: 'Definition', text: 'This is the evidence or the reason that proves your claim is true. It connects your idea to reality with facts, logic, or examples.' },
  { id: 'w2', term: 'warrant', tag: 'Example',    text: '"I need more time for homework and sports."' },
  { id: 'i1', term: 'impact',  tag: 'Definition', text: 'This explains why your argument actually matters. It shows the good things that happen if you\'re right, or the bad things that happen if you\'re ignored.' },
  { id: 'i2', term: 'impact',  tag: 'Example',    text: '"I will get better grades and be successful."' },
];

// ── State ──
let correct = 0, attempts = 0, streak = 0, bestStreak = 0, remaining = 6;
let draggedId = null;

// ── Stars ──
(function makeStars(){
  const sf = document.getElementById('starfield');
  for(let i = 0; i < 120; i++){
    const s = document.createElement('span');
    const size = Math.random() * 2.5 + 0.5;
    Object.assign(s.style,{
      width: size+'px', height: size+'px',
      left: Math.random()*100+'%', top: Math.random()*100+'%',
      '--dur': (Math.random()*3+2)+'s',
      animationDelay: Math.random()*4+'s',
    });
    sf.appendChild(s);
  }
})();

// ── Shuffle ──
function shuffle(a){ for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]} return a }

// ── Render Cards ──
function renderCards(){
  const grid = document.getElementById('cargoGrid');
  grid.innerHTML = '';
  shuffle([...CARDS]).forEach(c => {
    const el = document.createElement('div');
    el.className = 'cargo-card';
    el.setAttribute('draggable','true');
    el.dataset.id = c.id;
    el.innerHTML = `<span class="card-tag">${c.tag}</span>${c.text}`;
    // Desktop drag
    el.addEventListener('dragstart', onDragStart);
    el.addEventListener('dragend', onDragEnd);
    // Touch
    el.addEventListener('touchstart', onTouchStart, {passive:false});
    el.addEventListener('touchmove', onTouchMove, {passive:false});
    el.addEventListener('touchend', onTouchEnd);
    grid.appendChild(el);
  });
}

// ── Desktop Drag ──
function onDragStart(e){
  draggedId = e.target.closest('.cargo-card').dataset.id;
  e.target.closest('.cargo-card').classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
}
function onDragEnd(e){ e.target.classList.remove('dragging'); draggedId = null; }

document.querySelectorAll('.terminal').forEach(t => {
  t.addEventListener('dragover', e => { e.preventDefault(); t.classList.add('drag-over'); });
  t.addEventListener('dragleave', () => t.classList.remove('drag-over'));
  t.addEventListener('drop', e => {
    e.preventDefault(); t.classList.remove('drag-over');
    if(draggedId) handleDrop(draggedId, t.dataset.term);
  });
});

// ── Touch Drag ──
let touchGhost = null, touchCardId = null, touchStarted = false;

function onTouchStart(e){
  const card = e.target.closest('.cargo-card');
  if(!card) return;
  touchCardId = card.dataset.id;
  touchStarted = true;
  card.classList.add('dragging');

  // Create ghost
  touchGhost = document.createElement('div');
  touchGhost.className = 'touch-ghost';
  touchGhost.textContent = card.textContent;
  document.body.appendChild(touchGhost);
  const t = e.touches[0];
  touchGhost.style.left = t.clientX + 'px';
  touchGhost.style.top = t.clientY + 'px';
}
function onTouchMove(e){
  if(!touchStarted) return;
  e.preventDefault();
  const t = e.touches[0];
  if(touchGhost){
    touchGhost.style.left = t.clientX + 'px';
    touchGhost.style.top = t.clientY + 'px';
  }
  // Highlight terminal under finger
  document.querySelectorAll('.terminal').forEach(term => {
    const r = term.getBoundingClientRect();
    if(t.clientX >= r.left && t.clientX <= r.right && t.clientY >= r.top && t.clientY <= r.bottom){
      term.classList.add('drag-over');
    } else {
      term.classList.remove('drag-over');
    }
  });
}
function onTouchEnd(e){
  if(!touchStarted) return;
  touchStarted = false;
  if(touchGhost){ touchGhost.remove(); touchGhost = null; }
  const card = document.querySelector(`.cargo-card[data-id="${touchCardId}"]`);
  if(card) card.classList.remove('dragging');

  // Find terminal under last touch
  const t = e.changedTouches[0];
  let dropped = false;
  document.querySelectorAll('.terminal').forEach(term => {
    term.classList.remove('drag-over');
    const r = term.getBoundingClientRect();
    if(t.clientX >= r.left && t.clientX <= r.right && t.clientY >= r.top && t.clientY <= r.bottom){
      handleDrop(touchCardId, term.dataset.term);
      dropped = true;
    }
  });
  touchCardId = null;
}

// ── Drop Logic ──
function handleDrop(cardId, termName){
  const cardData = CARDS.find(c => c.id === cardId);
  if(!cardData) return;
  attempts++;

  if(cardData.term === termName){
    // Correct
    correct++; streak++; if(streak > bestStreak) bestStreak = streak;
    remaining--;

    // Move card visually
    const cardEl = document.querySelector(`.cargo-card[data-id="${cardId}"]`);
    if(cardEl) cardEl.remove();

    const landed = document.getElementById('landed-' + termName);
    const lc = document.createElement('div');
    lc.className = `landed-card ${termName}-card`;
    lc.innerHTML = `<span style="font-size:.6rem;font-family:'Orbitron';letter-spacing:1.5px;opacity:.6;display:block;margin-bottom:3px">${cardData.tag}</span>${cardData.text}`;
    landed.appendChild(lc);

    showFeedback('DOCKED!', 'correct');
    // Hide hint
    const terminal = document.getElementById('term-' + termName);
    const hint = terminal.querySelector('.terminal-hint');
    if(hint) hint.style.display = 'none';
  } else {
    // Wrong
    streak = 0;
    const terminal = document.getElementById('term-' + termName);
    terminal.classList.add('shake');
    setTimeout(() => terminal.classList.remove('shake'), 500);
    showFeedback('TRY AGAIN', 'wrong');
  }

  updateUI();
  if(remaining === 0) setTimeout(showWin, 700);
}

function showFeedback(text, type){
  const fb = document.getElementById('feedback');
  fb.textContent = text;
  fb.className = 'feedback-flash ' + type;
  // Force restart animation
  fb.style.animation = 'none';
  fb.offsetHeight;
  fb.style.animation = '';
}

function updateUI(){
  document.getElementById('scoreCorrect').textContent = correct;
  document.getElementById('scoreAttempts').textContent = attempts;
  document.getElementById('cardsLeft').textContent = remaining;
  document.getElementById('progressFill').style.width = ((6 - remaining)/6 * 100) + '%';
  const badge = document.getElementById('streakBadge');
  if(streak >= 2){ badge.classList.add('show'); document.getElementById('streakVal').textContent = streak; }
  else { badge.classList.remove('show'); }
}

// ── Win ──
function showWin(){
  const acc = attempts > 0 ? Math.round((correct / attempts) * 100) : 0;
  document.getElementById('winAccuracy').textContent = acc + '%';
  document.getElementById('winStreak').textContent = bestStreak;
  document.getElementById('winOverlay').classList.add('show');
  spawnConfetti();
}

function spawnConfetti(){
  const colors = ['#00e5ff','#ff6ef9','#76ff03','#ffc800','#ff3c3c','#fff'];
  for(let i = 0; i < 60; i++){
    const c = document.createElement('div');
    c.className = 'confetti-piece';
    c.style.left = Math.random()*100 + 'vw';
    c.style.background = colors[Math.floor(Math.random()*colors.length)];
    c.style.setProperty('--fall-dur', (Math.random()*2+2) + 's');
    c.style.setProperty('--rot', (Math.random()*720-360) + 'deg');
    c.style.animationDelay = Math.random()*1.5 + 's';
    c.style.borderRadius = Math.random()>.5 ? '50%' : '2px';
    c.style.width = (Math.random()*6+4)+'px';
    c.style.height = (Math.random()*6+4)+'px';
    document.body.appendChild(c);
    setTimeout(()=>c.remove(), 5000);
  }
}

function restartGame(){
  correct=0; attempts=0; streak=0; bestStreak=0; remaining=6;
  document.getElementById('winOverlay').classList.remove('show');
  ['claim','warrant','impact'].forEach(t=>{
    document.getElementById('landed-'+t).innerHTML='';
    const hint = document.getElementById('term-'+t).querySelector('.terminal-hint');
    if(hint) hint.style.display='';
  });
  updateUI();
  renderCards();
}

// ── Init ──
renderCards();
updateUI();
</script>


</body></html>
