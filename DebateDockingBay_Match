<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Policy Debate: Space Station Match</title>
<link href="./DebateDockingBay_Match_files/css2" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

:root{
  --bg-deep:#080b1a;
  --bg-panel:rgba(12,18,44,0.85);
  --border-glow:rgba(100,180,255,0.15);
  --claim-color:#00e5ff;
  --claim-bg:rgba(0,229,255,0.08);
  --claim-border:rgba(0,229,255,0.4);
  --warrant-color:#ff6ef9;
  --warrant-bg:rgba(255,110,249,0.08);
  --warrant-border:rgba(255,110,249,0.4);
  --impact-color:#76ff03;
  --impact-bg:rgba(118,255,3,0.08);
  --impact-border:rgba(118,255,3,0.4);
  --text-primary:#e0e8f8;
  --text-dim:#7b8db5;
  --star-color:#fff;
  --success-glow:rgba(118,255,3,0.6);
  --error-glow:rgba(255,60,60,0.6);
}

html,body{
  height:100%;
  font-family:'Exo 2',sans-serif;
  background:var(--bg-deep);
  color:var(--text-primary);
  overflow-x:hidden;
}

/* ── Stars ── */
.starfield{position:fixed;inset:0;pointer-events:none;z-index:0}
.starfield span{
  position:absolute;
  border-radius:50%;
  background:var(--star-color);
  animation:twinkle var(--dur) ease-in-out infinite alternate;
}
@keyframes twinkle{0%{opacity:.15;transform:scale(.8)}100%{opacity:1;transform:scale(1.2)}}

/* floating nebula blobs */
.nebula{
  position:fixed;
  border-radius:50%;
  filter:blur(100px);
  opacity:.12;
  pointer-events:none;
  z-index:0;
}
.nebula-1{width:500px;height:500px;top:-120px;left:-100px;background:radial-gradient(circle,#0055ff,transparent)}
.nebula-2{width:400px;height:400px;bottom:-80px;right:-60px;background:radial-gradient(circle,#a800ff,transparent)}
.nebula-3{width:350px;height:350px;top:40%;left:55%;background:radial-gradient(circle,#00ffa2,transparent);opacity:.07}

/* ── Layout ── */
.game-wrapper{
  position:relative;
  z-index:1;
  max-width:1100px;
  margin:0 auto;
  padding:24px 20px 40px;
  min-height:100vh;
  display:flex;
  flex-direction:column;
}

/* ── Header ── */
.header{text-align:center;margin-bottom:28px;position:relative}
.header-badge{
  display:inline-flex;align-items:center;gap:8px;
  font-family:'Orbitron',sans-serif;
  font-size:.65rem;letter-spacing:3px;text-transform:uppercase;
  color:var(--text-dim);
  background:var(--bg-panel);
  border:1px solid var(--border-glow);
  border-radius:40px;padding:6px 18px;margin-bottom:14px;
}
.header-badge .dot{width:6px;height:6px;border-radius:50%;background:#0f0;box-shadow:0 0 6px #0f0;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.header h1{
  font-family:'Orbitron',sans-serif;font-size:clamp(1.4rem,4vw,2.2rem);
  font-weight:900;letter-spacing:2px;
  background:linear-gradient(135deg,#00e5ff,#ff6ef9,#76ff03);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  margin-bottom:6px;
}
.header p{color:var(--text-dim);font-size:.95rem;font-weight:300}

/* ── Score Bar ── */
.score-bar{
  display:flex;align-items:center;justify-content:center;gap:24px;
  margin-bottom:24px;flex-wrap:wrap;
}
.score-item{
  display:flex;align-items:center;gap:6px;
  font-family:'Orbitron',sans-serif;font-size:.75rem;
  color:var(--text-dim);letter-spacing:1px;
}
.score-item .val{color:var(--text-primary);font-weight:700;font-size:1rem}
.streak-badge{
  background:linear-gradient(135deg,rgba(255,200,0,0.15),rgba(255,120,0,0.15));
  border:1px solid rgba(255,180,0,0.3);
  color:#ffc800;border-radius:20px;padding:4px 14px;
  font-weight:600;font-size:.75rem;
  animation:glow-streak 1.5s ease-in-out infinite alternate;
  display:none;
}
.streak-badge.show{display:inline-flex;align-items:center;gap:4px}
@keyframes glow-streak{0%{box-shadow:0 0 8px rgba(255,200,0,0.2)}100%{box-shadow:0 0 20px rgba(255,200,0,0.4)}}

/* ── Game Area ── */
.game-area{
  display:grid;
  grid-template-columns:1fr;
  gap:24px;
  flex:1;
}

/* Drop Zones (Terminals) */
.terminals{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}
.terminal{
  background:var(--bg-panel);
  border:2px dashed var(--border-glow);
  border-radius:16px;
  padding:20px 16px;
  text-align:center;
  transition:all .3s ease;
  min-height:160px;
  display:flex;flex-direction:column;align-items:center;
  position:relative;
  overflow:hidden;
}
.terminal::before{
  content:'';position:absolute;inset:0;border-radius:14px;
  opacity:0;transition:opacity .3s;pointer-events:none;
}
.terminal[data-term="claim"]::before{background:radial-gradient(ellipse at center,var(--claim-bg),transparent 70%)}
.terminal[data-term="warrant"]::before{background:radial-gradient(ellipse at center,var(--warrant-bg),transparent 70%)}
.terminal[data-term="impact"]::before{background:radial-gradient(ellipse at center,var(--impact-bg),transparent 70%)}
.terminal.drag-over::before{opacity:1}
.terminal.drag-over{transform:scale(1.02)}
.terminal.drag-over[data-term="claim"]{border-color:var(--claim-color);box-shadow:0 0 30px var(--claim-bg)}
.terminal.drag-over[data-term="warrant"]{border-color:var(--warrant-color);box-shadow:0 0 30px var(--warrant-bg)}
.terminal.drag-over[data-term="impact"]{border-color:var(--impact-color);box-shadow:0 0 30px var(--impact-bg)}

.terminal-icon{font-size:1.8rem;margin-bottom:8px;filter:drop-shadow(0 0 8px currentColor)}
.terminal[data-term="claim"] .terminal-icon{color:var(--claim-color)}
.terminal[data-term="warrant"] .terminal-icon{color:var(--warrant-color)}
.terminal[data-term="impact"] .terminal-icon{color:var(--impact-color)}

.terminal-label{
  font-family:'Orbitron',sans-serif;font-size:1.1rem;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;margin-bottom:4px;
}
.terminal[data-term="claim"] .terminal-label{color:var(--claim-color)}
.terminal[data-term="warrant"] .terminal-label{color:var(--warrant-color)}
.terminal[data-term="impact"] .terminal-label{color:var(--impact-color)}

.terminal-hint{font-size:.7rem;color:var(--text-dim);letter-spacing:1px;text-transform:uppercase;opacity:.7}
.terminal .landed-items{width:100%;margin-top:12px;display:flex;flex-direction:column;gap:8px}

.landed-card{
  border-radius:10px;padding:10px 14px;
  font-size:.82rem;font-weight:500;
  text-align:left;line-height:1.45;
  animation:land .4s cubic-bezier(.34,1.56,.64,1);
  position:relative;
}
@keyframes land{0%{opacity:0;transform:scale(.8) translateY(-10px)}100%{opacity:1;transform:scale(1) translateY(0)}}
.landed-card.claim-card{background:var(--claim-bg);border:1px solid var(--claim-border);color:var(--claim-color)}
.landed-card.warrant-card{background:var(--warrant-bg);border:1px solid var(--warrant-border);color:var(--warrant-color)}
.landed-card.impact-card{background:var(--impact-bg);border:1px solid var(--impact-border);color:var(--impact-color)}

/* ── Draggable Cards (Cargo) ── */
.cargo-bay{
  background:var(--bg-panel);
  border:1px solid var(--border-glow);
  border-radius:16px;
  padding:20px;
}
.cargo-label{
  font-family:'Orbitron',sans-serif;font-size:.65rem;
  letter-spacing:3px;text-transform:uppercase;
  color:var(--text-dim);margin-bottom:14px;
  display:flex;align-items:center;gap:8px;
}
.cargo-label::after{content:'';flex:1;height:1px;background:var(--border-glow)}

.cargo-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:12px;
}

.cargo-card{
  background:rgba(20,28,58,0.9);
  border:1px solid rgba(100,160,255,0.12);
  border-radius:12px;
  padding:14px 16px;
  font-size:.88rem;
  line-height:1.5;
  font-weight:400;
  color:var(--text-primary);
  cursor:grab;
  transition:all .25s ease;
  user-select:none;
  -webkit-user-select:none;
  position:relative;
  overflow:hidden;
}
.cargo-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--claim-color),var(--warrant-color),var(--impact-color));
  opacity:.4;transition:opacity .3s;
}
.cargo-card:hover{
  transform:translateY(-3px);
  border-color:rgba(100,180,255,0.3);
  box-shadow:0 8px 30px rgba(0,0,0,0.4);
}
.cargo-card:hover::before{opacity:1}
.cargo-card:active{cursor:grabbing;transform:scale(.97)}
.cargo-card.dragging{opacity:.35;transform:scale(.95)}
.cargo-card .card-tag{
  display:inline-block;font-size:.6rem;font-family:'Orbitron',sans-serif;
  letter-spacing:2px;text-transform:uppercase;
  color:var(--text-dim);margin-bottom:6px;
  background:rgba(100,160,255,0.06);
  border:1px solid rgba(100,160,255,0.1);
  border-radius:4px;padding:2px 8px;
}

/* ── Feedback ── */
.feedback-flash{
  position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);
  font-family:'Orbitron',sans-serif;font-size:2rem;font-weight:900;
  letter-spacing:4px;pointer-events:none;z-index:100;
  text-shadow:0 0 40px currentColor;
  opacity:0;
}
.feedback-flash.correct{color:#76ff03;animation:flash-in .7s cubic-bezier(.34,1.56,.64,1) forwards}
.feedback-flash.wrong{color:#ff3c3c;animation:flash-in .7s cubic-bezier(.34,1.56,.64,1) forwards}
@keyframes flash-in{
  0%{opacity:0;transform:translate(-50%,-50%) scale(0) rotate(-10deg)}
  40%{opacity:1;transform:translate(-50%,-50%) scale(1.15) rotate(2deg)}
  100%{opacity:0;transform:translate(-50%,-50%) scale(.9) translateY(-40px) rotate(0deg)}
}

/* ── Shake ── */
.shake{animation:shake .45s ease}
@keyframes shake{
  0%,100%{transform:translateX(0)}
  15%{transform:translateX(-8px)}
  30%{transform:translateX(8px)}
  45%{transform:translateX(-6px)}
  60%{transform:translateX(6px)}
  75%{transform:translateX(-3px)}
  90%{transform:translateX(3px)}
}

/* ── Win Screen ── */
.win-overlay{
  position:fixed;inset:0;z-index:200;
  background:rgba(4,6,18,0.92);
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:20px;
  opacity:0;pointer-events:none;
  transition:opacity .5s ease;
  backdrop-filter:blur(8px);
}
.win-overlay.show{opacity:1;pointer-events:all}
.win-title{
  font-family:'Orbitron',sans-serif;font-size:clamp(1.6rem,5vw,3rem);
  font-weight:900;letter-spacing:4px;
  background:linear-gradient(135deg,#76ff03,#00e5ff,#ff6ef9);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  animation:win-glow 2s ease-in-out infinite alternate;
  text-align:center;
}
@keyframes win-glow{0%{filter:brightness(1)}100%{filter:brightness(1.3)}}
.win-sub{color:var(--text-dim);font-size:1rem;text-align:center;max-width:440px;line-height:1.6}
.win-stats{display:flex;gap:32px;flex-wrap:wrap;justify-content:center}
.win-stat{text-align:center}
.win-stat .ws-val{font-family:'Orbitron',sans-serif;font-size:1.6rem;font-weight:900;color:var(--claim-color)}
.win-stat .ws-label{font-size:.7rem;color:var(--text-dim);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.btn-restart{
  font-family:'Orbitron',sans-serif;font-size:.8rem;
  letter-spacing:3px;text-transform:uppercase;
  background:linear-gradient(135deg,rgba(0,229,255,0.15),rgba(255,110,249,0.15));
  border:1px solid rgba(100,180,255,0.3);
  color:var(--text-primary);
  padding:14px 36px;border-radius:50px;cursor:pointer;
  transition:all .3s;
}
.btn-restart:hover{
  background:linear-gradient(135deg,rgba(0,229,255,0.25),rgba(255,110,249,0.25));
  box-shadow:0 0 30px rgba(100,180,255,0.2);
  transform:translateY(-2px);
}

/* ── Confetti ── */
.confetti-piece{
  position:fixed;top:-20px;width:8px;height:8px;
  z-index:210;pointer-events:none;
  animation:confetti-fall var(--fall-dur) linear forwards;
}
@keyframes confetti-fall{
  0%{transform:translateY(0) rotate(0deg);opacity:1}
  85%{opacity:1}
  100%{transform:translateY(110vh) rotate(var(--rot));opacity:0}
}

/* ── Progress ── */
.progress-bar{
  width:100%;height:4px;background:rgba(100,160,255,0.08);
  border-radius:4px;margin-bottom:20px;overflow:hidden;
}
.progress-fill{
  height:100%;border-radius:4px;
  background:linear-gradient(90deg,var(--claim-color),var(--warrant-color),var(--impact-color));
  transition:width .5s cubic-bezier(.34,1.56,.64,1);
  width:0%;
}

/* ── Mobile Touch Support ── */
.touch-ghost{
  position:fixed;pointer-events:none;z-index:150;
  background:rgba(20,28,58,0.95);
  border:2px solid rgba(100,180,255,0.4);
  border-radius:12px;padding:12px 16px;
  font-size:.85rem;color:var(--text-primary);
  max-width:280px;
  box-shadow:0 12px 40px rgba(0,0,0,0.6);
  transform:translate(-50%,-50%) rotate(-2deg) scale(1.05);
  opacity:.95;
}

/* ── Responsive ── */
@media(max-width:768px){
  .terminals{grid-template-columns:1fr}
  .cargo-grid{grid-template-columns:1fr}
  .game-wrapper{padding:16px 12px 32px}
  .terminal{min-height:auto;padding:16px 12px}
}
@media(min-width:769px) and (max-width:1024px){
  .terminals{grid-template-columns:repeat(3,1fr)}
  .cargo-grid{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
